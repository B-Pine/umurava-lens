# ---- Core ----
PORT=5000
NODE_ENV=development

# ---- MongoDB ----
# Local:    mongodb://localhost:27017/umurava-lens
# Atlas:    mongodb+srv://USER:PASS@cluster.mongodb.net/umurava-lens
MONGODB_URI=mongodb://localhost:27017/umurava-lens

# ---- Google Gemini (REQUIRED) ----
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ---- Auth / JWT ----
JWT_SECRET=change-me-to-a-long-random-string

# ---- Admin seeding ----
# Values used by `npm run seed` to create the initial recruiter account.
SEED_ADMIN_EMAIL=admin@umurava.africa
SEED_ADMIN_PASSWORD=umurava-admin-2026
SEED_ADMIN_NAME=Umurava Admin

# ---- Email outreach (SMTP) ----
# If any of SMTP_HOST / SMTP_PORT / SMTP_USER / SMTP_PASS is missing,
# the backend falls back to nodemailer's Ethereal test inbox and returns
# preview URLs instead of delivering real email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Umurava Lens <no-reply@umurava.africa>"

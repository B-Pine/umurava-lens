# ---- Core ----
PORT=5000
NODE_ENV=development

# ---- MongoDB ----
# Local:    mongodb://localhost:27017/umurava-lens
# Atlas:    mongodb+srv://USER:PASS@cluster.mongodb.net/umurava-lens
MONGODB_URI=mongodb://localhost:27017/umurava-lens

# ---- Google Gemini (REQUIRED) ----
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ---- Auth / JWT ----
JWT_SECRET=change-me-to-a-long-random-string

# ---- Admin seeding ----
# Values used by `npm run seed` to create the initial recruiter account.
SEED_ADMIN_EMAIL=admin@umurava.africa
SEED_ADMIN_PASSWORD=umurava-admin-2026
SEED_ADMIN_NAME=Umurava Admin

# ---- Email outreach ----
# Driver is picked in this order:
#   1. RESEND_API_KEY set      → Resend HTTPS API (REQUIRED on Render/Vercel/Heroku
#                                free tiers — they block outbound SMTP ports).
#   2. Full SMTP_* set         → nodemailer over SMTP (works on paid hosts / locally).
#   3. Neither set, dev only   → Ethereal test inbox (preview URLs, no real delivery).
#                                In production, missing config throws on first send.

# Resend (recommended for production). Get a key at https://resend.com/api-keys.
RESEND_API_KEY=

# Sender address. Use a verified domain in Resend, or "onboarding@resend.dev"
# while testing (Resend will only deliver to your signup email until a domain
# is verified).
EMAIL_FROM="Umurava Lens <onboarding@resend.dev>"

# SMTP fallback (only used if RESEND_API_KEY is empty).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Umurava Lens <no-reply@umurava.africa>"
